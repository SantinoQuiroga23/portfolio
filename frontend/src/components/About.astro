---
const stats = [
  { value: '4+',   label: 'años de exp.' },
  { value: '12+',  label: 'proyectos'    },
  { value: '100%', label: 'satisfacción' },
];

const currentTags = ['FastAPI', 'Astro', 'PostgreSQL', 'React', 'Python'];
const pastTags    = ['Análisis', 'Soporte', 'Corporativo'];
---

<section id="about" class="max-w-7xl mx-auto px-4 sm:px-6 py-20 sm:py-28 border-t border-white/[0.06]">

  <!-- Eyebrow -->
  <div class="section-eyebrow mb-10 sm:mb-14">
    <span class="font-mono text-[0.63rem] text-blue-500 tracking-[0.1em]">01</span>
    <span class="w-10 h-px bg-white/[0.08]"></span>
    <span class="font-mono text-[0.63rem] uppercase tracking-[0.22em] text-zinc-400">El Enfoque</span>
  </div>

  <div class="grid lg:grid-cols-2 gap-10 sm:gap-14 items-start">

    <!-- Copy -->
    <div>
      <h2 class="font-display text-[clamp(1.75rem,3.5vw,2.9rem)] font-bold leading-[1.12] tracking-tight text-zinc-100 mb-6">
        Modernización Digital<br/>para Empresas que Crecen
      </h2>

      <p class="text-zinc-400 text-[0.95rem] sm:text-[0.97rem] leading-[1.85] mb-4">
        Soy <strong class="text-zinc-200 font-medium">Desarrollador Fullstack</strong> y Arquitecto de Software con un objetivo claro:
        llevar a las empresas del presente al futuro tecnológico.
        Diseño e implemento soluciones digitales que eliminan procesos obsoletos y abren nuevas
        oportunidades de crecimiento.
      </p>

      <p class="text-zinc-400 text-[0.95rem] sm:text-[0.97rem] leading-[1.85] mb-4">
        Desde <strong class="text-zinc-200 font-medium">sistemas ERP a medida</strong> hasta
        <strong class="text-zinc-200 font-medium">páginas web de alto impacto</strong>, mi trabajo integra
        el stack moderno con una visión estratégica del negocio.
        No solo escribo código — entiendo el problema, propongo la arquitectura y acompaño la transformación.
      </p>

      <p class="text-zinc-400 text-[0.95rem] sm:text-[0.97rem] leading-[1.85]">
        Mi metodología combina sobriedad técnica con innovación constante:
        sistemas <strong class="text-zinc-200 font-medium">stateless</strong>, APIs de alta performance,
        interfaces modernas y pipelines de datos que le dan a cada empresa
        una ventaja operativa real.
      </p>

      <!-- Stats -->
      <div class="flex items-center gap-6 sm:gap-8 mt-10 pt-8 border-t border-white/[0.07]">
        {stats.map((s, i) => (
          <>
            <div class="text-center">
              <span class="block font-display text-[1.8rem] sm:text-[2rem] font-black text-zinc-100 leading-none">{s.value}</span>
              <span class="block font-mono text-[0.55rem] sm:text-[0.57rem] uppercase tracking-[0.1em] text-zinc-400 mt-1">{s.label}</span>
            </div>
            {i < stats.length - 1 && <div class="w-px h-9 bg-white/[0.07]"></div>}
          </>
        ))}
      </div>
    </div>

    <!-- Timeline card -->
    <div class="rounded-2xl border border-white/[0.07] bg-[#0e0e10] p-6 sm:p-7 relative overflow-hidden">
      <div
        class="absolute inset-0 pointer-events-none
               bg-[radial-gradient(circle_at_85%_0%,rgba(59,130,246,0.05)_0%,transparent_55%)]"
        aria-hidden="true"
      ></div>

      <h3 class="flex items-center gap-2 font-mono text-[0.72rem] text-zinc-500 mb-7 sm:mb-8 tracking-wide">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="3" fill="#3b82f6"/>
          <circle cx="8" cy="8" r="7" stroke="#3b82f6" stroke-width="1" opacity="0.35"/>
        </svg>
        Trayectoria Profesional
      </h3>

      <div class="relative tl-track">

        <!-- Active -->
        <div class="relative pl-7 mb-7 sm:mb-8">
          <div class="absolute left-0 top-[7px] w-3 h-3 rounded-full bg-blue-500
               shadow-[0_0_0_4px_rgba(59,130,246,0.15)]"></div>
          <span class="block font-mono text-[0.6rem] uppercase tracking-[0.1em] text-blue-500 mb-0.5">
            2024 — Actualidad
          </span>
          <h4 class="text-sm font-semibold text-zinc-100 mb-1.5">Desarrollador Fullstack Freelance</h4>
          <p class="text-xs text-zinc-500 leading-[1.75] mb-2.5">
            Modernización de operaciones empresariales: ERP a medida, páginas web, automatización
            de procesos y APIs de alto rendimiento para el sector industrial y comercial.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {currentTags.map(t => (
              <span class="font-mono text-[0.57rem] px-2 py-0.5 rounded border border-white/[0.07] text-zinc-400">{t}</span>
            ))}
          </div>
        </div>

        <!-- Past -->
        <div class="relative pl-7">
          <div class="absolute left-0 top-[7px] w-3 h-3 rounded-full border-2 border-zinc-700 bg-[#080809]"></div>
          <span class="block font-mono text-[0.6rem] uppercase tracking-[0.1em] text-zinc-400 mb-0.5">
            Pasantía Estratégica
          </span>
          <h4 class="text-sm font-semibold text-zinc-100 mb-1.5">Grupo Martinez</h4>
          <p class="text-xs text-zinc-500 leading-[1.75] mb-2.5">
            Análisis de sistemas internos y soporte técnico especializado en entornos corporativos de gran escala.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {pastTags.map(t => (
              <span class="font-mono text-[0.57rem] px-2 py-0.5 rounded border border-white/[0.07] text-zinc-400">{t}</span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>