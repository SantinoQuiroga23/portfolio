---
// src/components/dashboard/IcHeader.astro
// Cabecera del dashboard: logo, título, timestamp y Health LED.
---

<header class="ic-header">
  <!-- Left: logo + title -->
  <div class="ic-header-left">
    <div class="ic-logo-mark">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <rect x="1"  y="1"  width="6" height="6" rx="1" fill="#3b82f6" opacity="0.9"/>
        <rect x="11" y="1"  width="6" height="6" rx="1" fill="#3b82f6" opacity="0.5"/>
        <rect x="1"  y="11" width="6" height="6" rx="1" fill="#3b82f6" opacity="0.5"/>
        <rect x="11" y="11" width="6" height="6" rx="1" fill="#3b82f6" opacity="0.9"/>
      </svg>
    </div>
    <div>
      <h1 class="ic-title">Panel de Control Industrial</h1>
      <p class="ic-subtitle">La Pampa · Sistema de Monitoreo en Tiempo Real</p>
    </div>
  </div>

  <!-- Right: clock + health badge -->
  <div class="ic-header-right">
    <span id="ic-timestamp" class="ic-timestamp">--:--:--</span>

    <div class="ic-health-badge" id="ic-health-badge">
      <span class="ic-led" id="ic-led"></span>
      <span class="ic-health-text" id="ic-health-text">Verificando...</span>
    </div>
  </div>
</header>

<!-- Offline banner — oculto por defecto, JS lo muestra si backend cae -->
<div id="ic-offline-banner" class="ic-offline-banner ic-hidden">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
    <line x1="12" y1="9"  x2="12"   y2="13"/>
    <line x1="12" y1="17" x2="12.01" y2="17"/>
  </svg>
  <span>Backend no disponible — Los controles están deshabilitados. Reintentando conexión...</span>
</div>

<style>
  /* ── Header layout ── */
  .ic-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .ic-header-left  { display: flex; align-items: center; gap: 0.85rem; }
  .ic-header-right { display: flex; align-items: center; gap: 1rem; }

  /* Logo mark */
  .ic-logo-mark {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    background: var(--blue-dim);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 8px;
    flex-shrink: 0;
  }

  /* Title */
  .ic-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
  }
  .ic-subtitle {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin: 0;
    margin-top: 1px;
  }

  /* Clock */
  .ic-timestamp {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* Health badge */
  .ic-health-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--border-2);
    background: var(--surface);
  }

  /* LED */
  .ic-led {
    display: block;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--muted-2);
    transition: background 0.4s;
  }
  :global(.ic-led--online) {
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
    animation: ledPulse 2s ease-in-out infinite;
  }
  :global(.ic-led--offline) {
    background: var(--red);
    box-shadow: 0 0 6px var(--red);
  }
  :global(.ic-led--checking) {
    background: var(--amber);
    animation: ledBlink 0.8s ease-in-out infinite;
  }

  @keyframes ledPulse {
    0%, 100% { box-shadow: 0 0 4px var(--green); }
    50%       { box-shadow: 0 0 10px var(--green); }
  }
  @keyframes ledBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  /* Health text */
  .ic-health-text {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--muted);
    letter-spacing: 0.06em;
  }
  :global(.ic-health-text--online)  { color: var(--green); }
  :global(.ic-health-text--offline) { color: var(--red); }

  /* Offline banner */
  .ic-offline-banner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1rem;
    margin-bottom: 1.25rem;
    border-radius: var(--radius);
    background: var(--red-dim);
    border: 1px solid rgba(239, 68, 68, 0.25);
    color: #fca5a5;
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ic-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .ic-header-right { width: 100%; justify-content: space-between; }
  }

  @media (max-width: 560px) {
    .ic-title     { font-size: 0.88rem; }
    .ic-subtitle  { display: none; }
    .ic-timestamp { display: none; }
  }

  @media (max-width: 380px) {
    .ic-logo-mark   { display: none; }
    .ic-health-text { display: none; }
    .ic-offline-banner span { font-size: 0.72rem; }
  }
</style>
