---
// src/components/dashboard/IcTelemetryPanel.astro
// Panel de telemetría en vivo — tabla con polling automático cada 5s.
---

<section class="ic-panel ic-panel--telemetry" aria-labelledby="telemetry-heading">
  <!-- Header -->
  <div class="ic-panel-header">
    <div class="ic-panel-icon ic-panel-icon--green">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
    </div>
    <h2 id="telemetry-heading" class="ic-panel-title">Telemetría en Vivo</h2>
    <div class="ic-panel-header-right">
      <div class="ic-pulse-dot" id="ic-telem-pulse"></div>
      <span class="ic-panel-badge">↻ 5s</span>
    </div>
  </div>

  <!-- Last updated -->
  <p class="ic-telem-updated">
    Última actualización: <span id="ic-telem-ts">—</span>
  </p>

  <!-- Table -->
  <div class="ic-table-wrapper">
    <table class="ic-table" aria-label="Telemetría industrial en tiempo real">
      <thead>
        <tr>
          <th>Sensor</th>
          <th>Valor</th>
          <th>Unidad</th>
          <th>Estado</th>
        </tr>
      </thead>
      <tbody id="ic-telem-tbody">
        <tr class="ic-telem-skeleton">
          <td colspan="4">
            <div class="ic-skeleton-row"></div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
  <div class="ic-telemetry-info">
    <div class="ic-info-header">

  <div class="relative inline-block bg-white/[0.03] border border-blue-500/20 rounded-2xl p-5 max-w-xl">
    
    <!-- Label flotante -->
    <div class="absolute -top-3 left-4 flex items-center gap-1.5 bg-[#080809] px-2">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 shadow-[0_0_6px_rgba(59,130,246,0.8)] animate-pulse"></span>
      <span class="font-mono text-[0.6rem] tracking-[0.18em] uppercase text-blue-400">
        Contexto de Operación Real
      </span>
    </div>

      <!-- Texto -->
      <p class="m-0 text-sm leading-7 text-zinc-400">
        Esta tabla simula la recepción de datos vía
        <strong class="text-zinc-200 font-medium">protocolo MQTT o Modbus</strong>.
        En una estación de servicio real, estos valores permiten monitorear el stock crítico
        de tanques y la salud de los surtidores, evitando paradas no programadas y derrames accidentales.
      </p>

  </div>
</div>
</section>

<style>
  /* ── Shared panel shell ── */
  .ic-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--panel-pad);
    display: flex; flex-direction: column; gap: 1rem;
    position: relative; overflow: hidden;
  }
  .ic-panel::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 60px; height: 60px;
    background: radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.07), transparent 70%);
    pointer-events: none;
  }

  /* Panel header */
  .ic-panel-header {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
  }
  .ic-panel-icon {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 6px; flex-shrink: 0;
  }
  .ic-panel-icon--green { background: var(--green-dim); color: var(--green); }
  .ic-panel-title { font-size: 0.88rem; font-weight: 600; color: var(--text); margin: 0; flex: 1; }
  .ic-panel-badge {
    font-family: var(--font-mono); font-size: 0.58rem; color: var(--muted);
    letter-spacing: 0.05em; padding: 0.15rem 0.5rem;
    border-radius: 4px; border: 1px solid var(--border); background: var(--surface-2);
  }
  .ic-panel-header-right { display: flex; align-items: center; gap: 0.5rem; }

  /* Pulse dot */
  .ic-pulse-dot {
    width: 7px; height: 7px;
    border-radius: 50%; background: var(--muted-2);
  }
  :global(.ic-pulse-dot--active) {
    background: var(--green);
    animation: ledPulse 1.5s ease-in-out infinite;
  }
  @keyframes ledPulse {
    0%, 100% { box-shadow: 0 0 4px var(--green); }
    50%       { box-shadow: 0 0 10px var(--green); }
  }

  /* Last updated */
  .ic-telem-updated {
    font-family: var(--font-mono); font-size: 0.6rem;
    color: var(--muted); margin: -0.25rem 0 0;
  }

  /* Table */
  .ic-table-wrapper {
    overflow-x: auto; border-radius: 7px; border: 1px solid var(--border);
  }
  .ic-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .ic-table thead tr { border-bottom: 1px solid var(--border); }
  .ic-table th {
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 500;
    color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase;
    text-align: left; background: var(--surface-2);
  }
  .ic-table td {
    padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--border);
    color: var(--text); font-size: 0.78rem;
  }
  .ic-table tr:last-child td { border-bottom: none; }
  .ic-table tbody tr { transition: background 0.15s; }
  .ic-table tbody tr:hover { background: rgba(255, 255, 255, 0.02); }

  /* Badges — inserted dynamically, needs :global */
  :global(.ic-badge) {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.15rem 0.5rem; border-radius: 4px;
    font-family: var(--font-mono); font-size: 0.6rem;
    font-weight: 600; letter-spacing: 0.06em;
  }
  :global(.ic-badge--nominal) { background: var(--green-dim); color: var(--green); }
  :global(.ic-badge--alert)   { background: var(--red-dim);   color: var(--red); }
  :global(.ic-badge--warning) { background: var(--amber-dim); color: var(--amber); }
  :global(.ic-badge-dot) {
    width: 5px; height: 5px; border-radius: 50%; background: currentColor;
  }

  /* Skeleton */
  .ic-skeleton-row {
    height: 14px; border-radius: 4px;
    background: linear-gradient(90deg, var(--surface-2) 25%, var(--surface) 50%, var(--surface-2) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  @keyframes shimmer { to { background-position: -200% 0; } }

  /* Scrollbar */
  .ic-table-wrapper::-webkit-scrollbar { width: 4px; }
  .ic-table-wrapper::-webkit-scrollbar-track { background: transparent; }
  .ic-table-wrapper::-webkit-scrollbar-thumb { background: var(--muted-2); border-radius: 4px; }

  /* Responsive */
  @media (max-width: 560px) {
    .ic-panel       { padding: 1rem; }
    .ic-panel-badge { display: none; }
    /* Hide unit column on small screens */
    .ic-table th:nth-child(3),
    .ic-table td:nth-child(3) { display: none; }
  }
</style>
