---
// src/components/dashboard/IcPricesPanel.astro
// Panel de precios corregido para compatibilidad total con dashboard-logic.ts
---

<section class="ic-panel ic-panel--prices" aria-labelledby="prices-heading">
  
  <div class="ic-panel-header">
    <div class="ic-panel-icon ic-panel-icon--amber">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="1" x2="12" y2="23"/>
        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
      </svg>
    </div>
    <h2 id="prices-heading" class="ic-panel-title">Precios de Combustible</h2>
    <span class="ic-panel-badge">GET /api/v1/precios</span>
  </div>

  <div class="ic-prices-controls">
    <select id="ic-localidad-select" class="ic-select">
      <option value="">Todas las localidades</option>
      <option value="GENERAL PICO">General Pico</option>
      <option value="REALICO">Realicó</option>
      <option value="SANTA ROSA">Santa Rosa</option>
    </select>
    
    <button id="ic-prices-btn" class="ic-btn ic-btn--refresh">
      <span id="ic-prices-btn-content" class="ic-btn-content">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.54"/>
        </svg>
        Actualizar
      </span>
    </button>
  </div>

  <div id="ic-prices-container" class="ic-prices-list">
    <div class="ic-empty-state">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 8px; opacity: 0.5;">
        <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
      </svg>
      <p>Esperando consulta de datos...</p>
    </div>
  </div>

  <div class="ic-telemetry-info ic-info--amber">
    <div class="ic-info-header">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>
      </svg>
      <span>Referencia de Mercado</span>
    </div>
    <p class="ic-info-description">
      Valores obtenidos de la base **Surtidores API**. Los precios reflejados corresponden a la última actualización de bandera oficial en la región seleccionada.
    </p>
  </div>
</section>

<style>
  .ic-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--panel-pad);
    display: flex; flex-direction: column; gap: 1rem;
    position: relative;
  }

  .ic-panel-header { display: flex; align-items: center; gap: 0.6rem; }
  .ic-panel-icon--amber { color: var(--amber); background: rgba(245, 158, 11, 0.1); width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 6px; }
  .ic-panel-title { font-size: 0.88rem; font-weight: 600; color: var(--text); margin: 0; flex: 1; }
  .ic-panel-badge { font-family: var(--font-mono); font-size: 0.55rem; color: var(--muted); border: 1px solid var(--border); padding: 2px 6px; border-radius: 4px; }

  /* Controls */
  .ic-prices-controls { display: flex; gap: 0.5rem; }
  .ic-select {
    flex: 1; background: var(--surface-2); border: 1px solid var(--border);
    color: var(--text); padding: 0.5rem; border-radius: 6px; font-size: 0.75rem; outline: none;
  }
  .ic-btn--refresh {
    background: var(--surface-2); border: 1px solid var(--border); color: var(--text);
    padding: 0 1rem; border-radius: 6px; cursor: pointer; font-size: 0.75rem; transition: 0.2s;
  }
  .ic-btn--refresh:hover { border-color: var(--amber); color: var(--amber); }

  /* Lista de Precios */
  .ic-prices-list {
    display: flex; flex-direction: column; gap: 0.5rem;
    min-height: 150px; max-height: 250px; overflow-y: auto;
    padding-right: 4px;
  }

  /* Clases inyectadas por JS (:global) */
  :global(.ic-price-row) {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.7rem 0.8rem; background: var(--surface-2);
    border: 1px solid var(--border); border-radius: 6px;
    animation: fadeIn 0.3s ease;
  }
  
  :global(.ic-price-product) { font-size: 0.75rem; font-weight: 700; color: var(--text); text-transform: uppercase; }
  :global(.ic-price-meta) { display: flex; align-items: center; gap: 10px; }
  :global(.ic-price-locality) { font-size: 0.6rem; color: var(--muted); font-family: var(--font-mono); }
  :global(.ic-price-bandera) { font-size: 0.55rem; color: var(--amber); border: 1px solid rgba(245, 158, 11, 0.3); padding: 1px 4px; border-radius: 3px; }
  :global(.ic-price-value) { font-family: var(--font-mono); font-weight: 800; color: var(--text); font-size: 0.85rem; }

  /* Texto Inferior Corregido */
  .ic-telemetry-info {
    margin-top: 0.5rem; padding: 0.8rem;
    background: rgba(245, 158, 11, 0.03);
    border-radius: 6px; border-left: 3px solid var(--amber);
  }
  .ic-info-header { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; color: var(--amber); font-size: 0.6rem; font-weight: 800; text-transform: uppercase; }
  .ic-info-description { font-size: 0.7rem; line-height: 1.4; color: var(--muted); margin: 0; }

  .ic-empty-state {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    height: 150px; color: var(--muted); font-size: 0.7rem; border: 1px dashed var(--border); border-radius: 8px;
  }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>