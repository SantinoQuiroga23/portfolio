---
// src/components/IndustrialControl.astro
// ─── Componente maestro ───────────────────────────────────────────
// Ensambla todos los subcomponentes del dashboard y provee:
//   • Variables CSS (design tokens) globales
//   • Estructura de grid
//   • Inyección del script principal (dashboard-logic.ts)
//
// Endpoints consumidos por dashboard-logic.ts:
//   GET  /health
//   POST /industrial/generar-y-despachar
//   GET  /industrial/telemetria
//   GET  /industrial/download-csv
//   GET  /estaciones/precios-actuales
//   GET  /analytics/comparativa-norte-pampeano

import IcToastContainer  from './dashboard/IcToastContainer.astro';
import IcHeader          from './dashboard/IcHeader.astro';
import IcDispatchPanel   from './dashboard/IcDispatchPanel.astro';
import IcTelemetryPanel  from './dashboard/IcTelemetryPanel.astro';
import IcPricesPanel     from './dashboard/IcPricesPanel.astro';
import IcAnalyticsPanel  from './dashboard/IcAnalyticsPanel.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
---

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link
  href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap"
  rel="stylesheet"
/>

<!--
  ic-root recibe data-api para que dashboard-logic.ts
  pueda leer el base URL sin hard-codear nada.
-->
<div id="ic-root" class="ic-root" data-api={API_BASE}>

  <!-- Notificaciones globales -->
  <IcToastContainer />

  <!-- Cabecera + banner offline -->
  <IcHeader />

  <!-- Grid de 4 paneles -->
  <div class="ic-grid">
    <IcDispatchPanel />
    <IcTelemetryPanel />
    <IcPricesPanel />
    <IcAnalyticsPanel />
  </div>

</div>

<!-- ── Script principal ──────────────────────────────────────────── -->
<!--
  Importamos el módulo TypeScript completo.
  Astro compilará y bundleará este archivo durante el build.
-->
<script>
  import '../lib/dashboard-logic';
</script>


<!-- ══════════════════════════════════════════════════════════════
     GLOBAL STYLES — Design tokens + layout base
     Los subcomponentes heredan estas variables CSS.
══════════════════════════════════════════════════════════════ -->
<style is:global>
  /* ── CSS Custom Properties (Design Tokens) ── */
  #ic-root, .ic-root {
    /* Backgrounds */
    --bg:         #09090b;
    --surface:    #0f0f12;
    --surface-2:  #141418;

    /* Borders */
    --border:     rgba(255, 255, 255, 0.06);
    --border-2:   rgba(255, 255, 255, 0.10);

    /* Brand colors */
    --blue:       #3b82f6;
    --blue-dim:   rgba(59, 130, 246, 0.12);
    --green:      #22c55e;
    --green-dim:  rgba(34, 197, 94, 0.12);
    --red:        #ef4444;
    --red-dim:    rgba(239, 68, 68, 0.12);
    --amber:      #f59e0b;
    --amber-dim:  rgba(245, 158, 11, 0.12);
    --violet:     #8b5cf6;
    --violet-dim: rgba(139, 92, 246, 0.12);

    /* Typography */
    --text:       #e4e4e7;
    --muted:      #52525b;
    --muted-2:    #3f3f46;
    --font-mono:  'JetBrains Mono', monospace;
    --font-body:  'DM Sans', system-ui, sans-serif;

    /* Layout */
    --radius:     10px;
    --panel-pad:  1.4rem;
  }

  /* ── Root wrapper ── */
  .ic-root {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 1.5rem;
    font-size: 14px;
  }

  /* ── Main grid ── */
  .ic-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  /* ── Shared utility ── */
  .ic-hidden { display: none !important; }

  /* ── Responsive grid ── */
  @media (max-width: 900px) {
    .ic-root { padding: 1rem; }
    .ic-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 560px) {
    .ic-root { padding: 0.75rem; }
  }
</style>
